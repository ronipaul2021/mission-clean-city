# ============================================================
# BM Project — Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual values below
#   3. NEVER commit the .env file to Git
#   4. Add .env to your .gitignore
# ============================================================

# Django Core
SECRET_KEY=django-insecure-replace-this-with-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Fast2SMS — OTP Service (https://www.fast2sms.com)
FAST2SMS_API_KEY=your-fast2sms-api-key-here

# Admin Bootstrap Secret (used only when zero admins exist)
ADMIN_REGISTRATION_SECRET=BMD@BIRNAGAR#2026

# Aadhaar Encryption Key — CRITICAL
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# This MUST be a valid Fernet key (32-byte base64-encoded).
# If you lose this key, all stored Aadhaar numbers become unreadable.
AADHAAR_ENCRYPTION_KEY=replace-with-output-of-the-python-command-above

# OTP Expiry (in minutes)
OTP_EXPIRY_MINUTES=10

# Email (SMTP) Settings for OTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=paulroni417@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=paulroni417@gmail.com
