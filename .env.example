# Django Settings
SECRET_KEY=django-insecure-your-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# SMS Gateway (Fast2SMS)
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Security Settings
ADMIN_REGISTRATION_SECRET=your_secret_phrase_for_admin_reg
AADHAAR_ENCRYPTION_KEY=your_base64_32_byte_key
OTP_EXPIRY_MINUTES=10

# SMTP Email Settings (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_specific_password
DEFAULT_FROM_EMAIL=your_email@gmail.com

# AI Chatbot Assistant (Birni)
# BYTEZ_API_KEY: Your token from https://bytez.com/api
BYTEZ_API_KEY=your_bytez_token_here

# GEMINI_API_KEY: Your Google AI Studio key from https://aistudio.google.com/
# This is used as the 'provider-key' in Bytez and as the direct fallback.
GEMINI_API_KEY=your_google_gemini_api_key_here
