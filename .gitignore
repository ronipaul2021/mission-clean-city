# ==============================================================================
# BM Project — .gitignore
# ==============================================================================

# Secrets — NEVER commit these
.env
*.env

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Django generated files
db.sqlite3
staticfiles/
media/

# Virtual environments
venv/
.venv/
env/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs & Caches
*.log
.cache/
django_cache/

# Distribution / packaging
dist/
build/
*.egg-info/
